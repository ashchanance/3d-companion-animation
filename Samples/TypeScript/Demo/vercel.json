{
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/haruka/buyback-cycle.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/haruka/buyback-cycle",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/about-us", "destination": "/about-us.html" },
    { "source": "/roadmap",  "destination": "/roadmap.html"  },
    { "source": "/docs",     "destination": "/docs.html"     },
    { "source": "/features", "destination": "/features.html" },
    { "source": "/x402",     "destination": "/x402.html"     },
    { "source": "/lore",     "destination": "/lore.html"     }
  ]
}
